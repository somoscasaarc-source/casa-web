# =============================================================
# CASA — Variables de entorno
# Pegá esto en Vercel: Project → Settings → Environment Variables.
# =============================================================

# --- Site (opcional pero recomendado cuando registres el dominio) ---
NEXT_PUBLIC_SITE_URL=https://casa-web-chi.vercel.app

# --- Public contact ---
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/5491139295625
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/somos.casa.ok/
NEXT_PUBLIC_EMAIL=somoscasa.ar@gmail.com

# --- Admin whitelist (separados por coma) ---
NEXT_PUBLIC_ADMIN_EMAILS=somoscasa.ar@gmail.com

# --- Supabase (Fase 2: galerías privadas) ---
# Sacalas de Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (mail transaccional) ---
RESEND_API_KEY=
RESEND_FROM=CASA <contacto@somoscasa.com.ar>

# --- MercadoPago (Fase 3: reservas, Fase 4: tienda) ---
# Sacalas de Mercado Pago → Tu negocio → Credenciales
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# --- Seña por reserva (en ARS, entero) ---
# Por ejemplo: 200000 = ARS 200.000 de seña fija
NEXT_PUBLIC_DEPOSIT_AMOUNT=
